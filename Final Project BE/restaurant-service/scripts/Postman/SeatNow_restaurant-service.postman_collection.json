{
  "info": {
    "name": "SeatNow Restaurant Service",
    "_postman_id": "restaurant-service-collection",
    "description": "Collection to test restaurant-service endpoints (CRUD, Menu, Reviews, Tables, Availability).\nBase URL: http://localhost:3003\nSetup: Login via Auth collection -> token saved to {{token}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3003" },
    { "key": "token", "value": "", "description": "Lay tu Auth - Login" },
    { "key": "restaurantId", "value": "", "description": "Auto-saved after Create Restaurant" },
    { "key": "restaurantOwnerId", "value": "<owner-uuid>" },
    { "key": "itemId", "value": "", "description": "Auto-saved after Create Menu Item" },
    { "key": "tableId", "value": "", "description": "Auto-saved after Create Table" },
    { "key": "availabilityDate", "value": "2026-12-20" },
    { "key": "availabilityTime", "value": "19:00" },
    { "key": "availabilityGuests", "value": "4" }
  ],
  "item": [
    {
      "name": "01. Health",
      "item": [
        {
          "name": "GET Health",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const res = pm.response.json();",
                  "pm.test('Service is healthy', function () {",
                  "    pm.expect(res).to.have.property('status');",
                  "    pm.expect(res.status).to.eql('ok');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health",
            "description": "Kiem tra trang thai hoat dong cua restaurant service."
          }
        }
      ]
    },
