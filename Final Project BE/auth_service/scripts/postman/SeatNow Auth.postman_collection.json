    {
      "name": "2. Register",
      "item": [
        {
          "name": "Register (with OTP)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const res = pm.response.json();",
                  "pm.test('Response has user data', function () {",
                  "    pm.expect(res).to.have.property('user');",
                  "    pm.expect(res.user).to.have.property('id');",
                  "    pm.expect(res.user).to.have.property('phone');",
                  "});",
                  "",
                  "pm.test('Response has tokens', function () {",
                  "    pm.expect(res).to.have.property('accessToken');",
                  "    pm.expect(res).to.have.property('refreshToken');",
                  "});",
                  "",
                  "if (res.accessToken && res.accessToken.accessToken) {",
                  "    pm.collectionVariables.set('token', res.accessToken.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', res.refreshToken.refreshToken);",
                  "    console.log('Saved tokens from register');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{phone}}\",\n  \"email\": \"test@example.com\",\n  \"name\": \"Test User\",\n  \"password\": \"P@ssw0rd!\",\n  \"otp\": \"123456\"\n}",
