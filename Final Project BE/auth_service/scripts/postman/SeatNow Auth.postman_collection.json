    {
      "name": "3. Login / Logout",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const res = pm.response.json();",
                  "pm.test('Response has accessToken', function () {",
                  "    pm.expect(res).to.have.property('accessToken');",
                  "    pm.expect(res.accessToken.accessToken).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "pm.test('Response has refreshToken', function () {",
                  "    pm.expect(res).to.have.property('refreshToken');",
                  "    pm.expect(res.refreshToken.refreshToken).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "pm.test('Response has user info', function () {",
                  "    pm.expect(res).to.have.property('user');",
                  "    pm.expect(res.user).to.have.property('id');",
                  "    pm.expect(res.user).to.have.property('role');",
                  "});",
                  "",
                  "if (res.accessToken && res.accessToken.accessToken) {",
                  "    pm.collectionVariables.set('token', res.accessToken.accessToken);",
                  "    console.log('Saved accessToken:', res.accessToken.accessToken.substring(0, 20) + '...');",
                  "}",
                  "if (res.refreshToken && res.refreshToken.refreshToken) {",
                  "    pm.collectionVariables.set('refreshToken', res.refreshToken.refreshToken);",
                  "    console.log('Saved refreshToken');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"{{phone}}\",\n  \"password\": \"P@ssw0rd!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "login"
              ]
            },
            "description": "Dang nhap bang so dien thoai hoac email va mat khau. Auto-save accessToken va refreshToken."
          },
          "response": []
        },
