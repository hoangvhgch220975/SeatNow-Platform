{
  "info": {
    "name": "SeatNow - Booking Service",
    "_postman_id": "booking-service-2026-v2",
    "description": "Complete API collection for SeatNow Booking Service with all endpoints and assertions.\nBase URL: http://localhost:3004\n\nSetup: Login via Auth collection to get {{token}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3004/api/v1", "type": "string" },
    { "key": "token", "value": "", "type": "string", "description": "Lay tu Auth - Login" },
    { "key": "restaurantId", "value": "1D106F0B-F292-405B-9E3A-76B219141863", "type": "string" },
    { "key": "tableId", "value": "7C326061-FB2C-4A2D-BC97-206C9127974A", "type": "string" },
    { "key": "bookingId", "value": "", "type": "string" },
    { "key": "bookingCode", "value": "", "type": "string" },
    { "key": "guestPhone", "value": "+84901234567", "type": "string" }
  ],
  "item": [
    {
      "name": "1. Public/Guest Operations",
      "item": [
        {
          "name": "Create Booking (Guest)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const res = pm.response.json();",
                  "const booking = res.data || res.booking || res;",
                  "pm.test('Booking created with code', function () {",
                  "    pm.expect(booking).to.have.property('id');",
                  "    pm.expect(booking).to.have.property('bookingCode');",
                  "});",
                  "",
                  "if (booking.id) {",
                  "    pm.collectionVariables.set('bookingId', booking.id);",
                  "    pm.collectionVariables.set('bookingCode', booking.bookingCode);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"restaurantId\": \"{{restaurantId}}\",\n  \"tableId\": \"{{tableId}}\",\n  \"bookingDate\": \"2026-12-25\",\n  \"bookingTime\": \"19:00\",\n  \"numGuests\": 4,\n  \"guestName\": \"Guest Test\",\n  \"guestPhone\": \"{{guestPhone}}\",\n  \"guestEmail\": \"guest@example.com\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/bookings"
          }
        },
        {
          "name": "Guest Lookup Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const res = pm.response.json();",
                  "pm.test('Found correct booking', function () {",
                  "    pm.expect(res.bookingCode || res.data.bookingCode).to.eql(pm.collectionVariables.get('bookingCode'));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/bookings/guest/lookup?bookingCode={{bookingCode}}&guestPhone={{guestPhone}}",
              "host": ["{{baseUrl}}"],
              "path": ["bookings", "guest", "lookup"],
              "query": [
                { "key": "bookingCode", "value": "{{bookingCode}}" },
                { "key": "guestPhone", "value": "{{guestPhone}}" }
              ]
            }
          }
        }
      ]
    },
