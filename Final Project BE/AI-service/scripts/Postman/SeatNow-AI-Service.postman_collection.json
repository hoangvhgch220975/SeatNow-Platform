			"name": "0. Health Check",
			"item": [
				{
					"name": "Health Check",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Service is running', function () {",
									"    const res = pm.response.json();",
									"    pm.expect(res.status).to.eql('OK');",
									"    pm.expect(res.service).to.include('SeatNow AI');",
									"    console.log('AI Service running on port:', res.port);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/health",
							"host": ["{{baseUrl}}"],
							"path": ["health"]
						},
						"description": "Check if the AI service is running."
					},
					"response": []
				}
			]
		},
		{
			"name": "1. Public AI (Guest Access)",
			"item": [
				{
					"name": "Guest Recommendation (No Auth)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response has recommendations field', function () {",
									"    const res = pm.response.json();",
									"    pm.expect(res).to.have.property('recommendations');",
									"    pm.expect(res.recommendations).to.be.a('string').and.not.empty;",
									"    console.log('Guest Recommendations preview:', res.recommendations.substring(0, 300) + '...');",
									"});",
									"",
									"pm.test('Performance: Response time is acceptable', function () {",
									"    // First call (DB) may be ~100-300ms, second call (Cache) should be much faster.",
									"    pm.expect(pm.response.responseTime).to.be.below(500);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
